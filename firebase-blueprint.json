{
  "entities": {
    "Licitacao": {
      "title": "Licitacao",
      "description": "Uma licitação acompanhada pela empresa, incluindo checklist de documentos, contatos de fornecedores, concorrentes e alertas.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "url": { "type": "string" },
        "edital": { "type": "string" },
        "orgao": { "type": "string" },
        "modalidade": { "type": "string" },
        "objeto": { "type": "string" },
        "valorEstimado": { "type": "number" },
        "dataSessao": { "type": "string" },
        "cidade": { "type": "string" },
        "estado": { "type": "string" },
        "categoria": { "type": "string" },
        "status": { "type": "string" },
        "historicStatus": { "type": "array" },
        "checklist": { "type": "array" },
        "suppliers": { "type": "array" },
        "competitors": { "type": "array" },
        "alerts": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "edital", "orgao", "modalidade", "status"]
    },
    "I_Audit_Log": {
      "title": "I_Audit_Log",
      "description": "Log de auditoria de transações realizadas com Inteligência Artificial para fins de governança e compliance.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "endpoint": { "type": "string" },
        "signature": { "type": "string" },
        "isMock": { "type": "boolean" },
        "payloadStr": { "type": "string" },
        "responseStr": { "type": "string" },
        "citationsStr": { "type": "string" }
      },
      "required": ["id", "userId", "timestamp", "endpoint", "signature"]
    }
  },
  "firestore": {
    "/licitacoes/{licitacaoId}": {
      "schema": "Licitacao",
      "description": "Coleção principal de licitações cadastradas."
    },
    "/ia_audit_logs/{logId}": {
      "schema": "I_Audit_Log",
      "description": "Logs persistidos de auditoria e compliance de IA."
    }
  }
}
